{
  "tools": {
    "@csssr/e2e-tools-codecept": {
      "browsers": {
        "local_chrome": {
          "default": true,
          "type": "playwright",
          "show": true,
          "browser": "chromium"
        },
        "local_firefox": {
          "type": "playwright",
          "browser": "firefox",
          "show": true
        },
        "remote_chrome": {
          "remote": true,
          "type": "selenium",

          "url": "https://selenium.csssr.cloud",
          "seleniumBasicAuth": {
            "credentialsId": "selenium",
            "username_env": "SELENIUM_USERNAME",
            "password_env": "SELENIUM_PASSWORD"
          },

          "browser": "chrome",
          "windowSize": "1920x1680",
          "desiredCapabilities": {
            "goog:chromeOptions": {
              "args": [
                "--headless",
                "--no-sandbox",
                "--disable-gpu",
                "--window-size=1200,800"
              ]
            }
          }
        }
      }
    }
  },
  "projectName": "codecept-playground",
  "defaultLaunchUrl": "https://csssr.com"
}
